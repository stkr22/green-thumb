# Copy to .env.local (gitignored) and fill in for local development.

# Zitadel OIDC application credentials
OIDC_ISSUER_URL=https://auth.example.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Random secret for signing session cookies, e.g. `openssl rand -hex 32`
SESSION_SECRET_KEY=

# ntfy push notifications (optional for local dev)
NTFY_URL=https://ntfy.example.com
NTFY_TOPIC=greenthumb
NTFY_TOKEN=

# FloraCodex species search (optional; empty disables the feature gracefully)
FLORACODEX_API_KEY=
